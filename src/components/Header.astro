---
import type { NavItem } from "../types";
interface Props { nav: NavItem[]; }
const { nav } = Astro.props;

// 現在ページに応じて Home / Works のアクティブを判定（末尾スラッシュを正規化）
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const siteNav = [
  { label: "Home", href: "/", current: path === "/" },
  { label: "Works", href: "/works", current: path === "/works" },
];
---
<header class="site-header">
  <div class="container">
    <a class="brand" href="/">ka<span class="dot">.</span>kii's website</a>
    <div class="header-right">
      <nav class="site-nav">
        {siteNav.map((item) => (
          <a href={item.href} {...item.current ? { "aria-current": "page" } : {}}>{item.label}</a>
        ))}
      </nav>
      <button class="menu-btn" type="button" aria-label="目次を開く" aria-expanded="false">
        <span></span><span></span>
      </button>
    </div>
  </div>
  <div class="menu-panel" hidden>
    {nav.map((item) => (
      <a href={`#${item.id}`}>
        <span class="pi-num">{item.num}</span><span class="pi-label">{item.label}</span>
      </a>
    ))}
  </div>
</header>
