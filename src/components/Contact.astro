---
import { PROFILE, SOCIAL_LINKS } from "../consts";
import ExtLink from "./ExtLink.astro";

const anyTentative = SOCIAL_LINKS.some((l) => l.tentative);

interface Props { num: string; }
const { num } = Astro.props;
---

<section class="section fade" id="contact">
  <div class="sec-num">{num}</div>
  <div>
    <header class="sec-head">
      <h2 class="sec-title">
        連絡先
        <span class="sec-title-en">Contact</span>
      </h2>
    </header>

    {
      PROFILE.email && (
        <>
          <a class="contact-mail" href={`mailto:${PROFILE.email.address}`}>{PROFILE.email.address}</a>
          {PROFILE.email.tentative && <span class="kari">（仮）</span>}
        </>
      )
    }

    <p class="contact-note">{PROFILE.contactNote}</p>

    <div class="contact-links">
      {SOCIAL_LINKS.map((l) => <ExtLink label={l.label} href={l.href} />)}
    </div>

    {anyTentative && <p class="kari-note">※ リンク先はすべて仮（未設定）</p>}
  </div>
</section>
